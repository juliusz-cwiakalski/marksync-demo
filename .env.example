# MarkSync demo credentials
# Copy to .env and fill in your values (Bun auto-loads .env from cwd)
# Never commit .env — it is gitignored.

# Confluence Cloud tenant URL
MARKSYNC_CONFLUENCE_BASE_URL=https://your-site.atlassian.net

# Confluence user email (must match the API token's account)
MARKSYNC_USER_EMAIL=you@example.com

# Confluence API token (classic/direct auth)
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
MARKSYNC_API_TOKEN=your-api-token-here
